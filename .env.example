# ===========================================================================
# ContractGuard — environment variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
#
# Get a free Groq API key at https://console.groq.com/keys
# Without GROQ_API_KEY the analyzer falls back to a deterministic keyword
# matcher so the demo still works end-to-end.
# ===========================================================================

# REQUIRED for the full AI pipeline (Extract → Match → Explain via Groq SDK)
GROQ_API_KEY=

# OPTIONAL — override the default Groq models
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=llama-3.2-90b-vision-preview

# OPTIONAL — only needed if you wire up the Prisma database
# DATABASE_URL=file:./db/custom.db
